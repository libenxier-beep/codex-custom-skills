{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Domain source manifest entry",
  "type": "object",
  "required": [
    "id",
    "type",
    "title",
    "url_or_path",
    "accessed_at",
    "quality",
    "summary",
    "derived_pages"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "enum": ["article", "architecture", "quote", "case", "code", "transcript", "report", "other"]
    },
    "title": { "type": "string", "minLength": 1 },
    "author_or_org": { "type": "string" },
    "url_or_path": { "type": "string", "minLength": 1 },
    "accessed_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "quality": { "type": "string", "enum": ["high", "medium", "low", "reject"] },
    "copyright_boundary": { "type": "string" },
    "summary": { "type": "string", "minLength": 1 },
    "derived_pages": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "notes": { "type": "string" }
  },
  "additionalProperties": true
}
