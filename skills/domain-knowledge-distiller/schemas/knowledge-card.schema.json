{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Knowledge card",
  "type": "object",
  "required": [
    "claim",
    "mechanism",
    "use_when",
    "do_not_use_when",
    "retrieval_keys",
    "source_refs",
    "confidence",
    "last_reviewed"
  ],
  "properties": {
    "claim": { "type": "string", "minLength": 1 },
    "mechanism": { "type": "string", "minLength": 1 },
    "use_when": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "do_not_use_when": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "retrieval_keys": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "last_reviewed": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
  },
  "additionalProperties": false
}
